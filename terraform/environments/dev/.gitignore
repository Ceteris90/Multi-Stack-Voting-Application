# Crash log files
crash.log
# Exclude .terraform directories in all subdirectories
**/.terraform/*
# Exclude .terraform directories in the current directory
.terraform/*
# Exclude .terraform directories in the parent directory
../.terraform/*
# Exclude .terraform directories in the root directory
/.terraform/*
# Exclude .terraform directories in any directory
**/.terraform/*
# Exclude .terraform directories in any directory, including hidden directories
**/.terraform/*
# Exclude .terraform directories in any directory, including hidden directories and subdirectories
**/.terraform/**/*
# Exclude .terraform directories in any directory, including hidden directories and subdirectories, and their contents
**/.terraform/**/*
# Exclude .terraform directories in any directory, including hidden directories and subdirectories, and their contents, but not the .terraform directories themselves
**/.terraform/**/*


# Exclude bootstrap folder in terraform directory
/terraform/bootstrap/





