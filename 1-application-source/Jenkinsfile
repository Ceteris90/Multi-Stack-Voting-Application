pipeline {
	agent any

	options {
		timestamps()
		disableConcurrentBuilds()
	}

	// Requires GitHub webhook configured to POST to: http(s)://<jenkins-url>/github-webhook/
	triggers {
		githubPush()
	}

	environment {
		SONAR_HOST_URL = 'http://localhost:9000'
		SONAR_TOKEN = ''
	}

	stages {
		stage('Checkout') {
			steps {
				checkout scm
				sh 'git rev-parse --short HEAD'
			}
		}

		stage('Validate Sonar Config') {
			steps {
				sh 'test -f 1-application-source/sonar-project.properties'
			}
		}

		stage('SonarQube Scan') {
			steps {
				sh '''
					set -e

					if ! command -v sonar-scanner >/dev/null 2>&1; then
						echo "sonar-scanner not found on Jenkins host. Install it at /usr/local/bin/sonar-scanner."
						exit 1
					fi

					EFFECTIVE_SONAR_HOST_URL="${SONAR_HOST_URL}"
					EFFECTIVE_SONAR_TOKEN="${SONAR_TOKEN}"
					EFFECTIVE_SONAR_USER="${SONAR_USER:-}"
					EFFECTIVE_SONAR_PASSWORD="${SONAR_PASSWORD:-}"

					if [ -n "${JOB_SONAR_HOST_URL:-}" ]; then
						EFFECTIVE_SONAR_HOST_URL="${JOB_SONAR_HOST_URL}"
					fi

					if [ -n "${JOB_SONAR_TOKEN:-}" ]; then
						EFFECTIVE_SONAR_TOKEN="${JOB_SONAR_TOKEN}"
					fi

					if [ -n "${JOB_SONAR_USER:-}" ]; then
						EFFECTIVE_SONAR_USER="${JOB_SONAR_USER}"
					fi

					if [ -n "${JOB_SONAR_PASSWORD:-}" ]; then
						EFFECTIVE_SONAR_PASSWORD="${JOB_SONAR_PASSWORD}"
					fi

					echo "Waiting for SonarQube to be reachable at ${EFFECTIVE_SONAR_HOST_URL}..."
					attempt=1
					max_attempts=24
					until curl -sSf --max-time 10 "${EFFECTIVE_SONAR_HOST_URL}/api/system/status" >/dev/null; do
						if [ "${attempt}" -ge "${max_attempts}" ]; then
							echo "Cannot reach SonarQube at ${EFFECTIVE_SONAR_HOST_URL} after $((max_attempts * 5)) seconds."
							exit 1
						fi
						echo "SonarQube not ready yet (attempt ${attempt}/${max_attempts}); retrying in 5s..."
						attempt=$((attempt + 1))
						sleep 5
					done
					echo "SonarQube is reachable."

					EXTRA_AUTH=""
					if [ -n "${EFFECTIVE_SONAR_TOKEN}" ]; then
						if curl -sS --max-time 10 -H "Authorization: Bearer ${EFFECTIVE_SONAR_TOKEN}" "${EFFECTIVE_SONAR_HOST_URL}/api/authentication/validate" | grep -q '"valid":true'; then
							EXTRA_AUTH="-Dsonar.token=${EFFECTIVE_SONAR_TOKEN}"
						else
							echo "WARN: Provided Sonar token is invalid. Falling back to username/password auth if available."
							EFFECTIVE_SONAR_TOKEN=""
						fi
					fi

					if [ -z "${EXTRA_AUTH}" ] && echo "${EFFECTIVE_SONAR_HOST_URL}" | grep -Eq '^http://(localhost|127\\.0\\.0\\.1)(:[0-9]+)?$'; then
						if curl -sS --max-time 10 -u admin:admin "${EFFECTIVE_SONAR_HOST_URL}/api/authentication/validate" | grep -q '"valid":true'; then
							tmp_token_name="jenkins-local-${BUILD_NUMBER}-$(date +%s)"
							tmp_sonar_token=$(curl -sS --max-time 10 -u admin:admin -X POST --data-urlencode "name=${tmp_token_name}" "${EFFECTIVE_SONAR_HOST_URL}/api/user_tokens/generate" | sed -n 's/.*"token":"\\([^"]*\\)".*/\\1/p')
							if [ -n "${tmp_sonar_token}" ]; then
								EXTRA_AUTH="-Dsonar.token=${tmp_sonar_token}"
								echo "WARN: Generated temporary local SonarQube token for this build."
							fi
						fi
					fi

					if [ -n "${EFFECTIVE_SONAR_TOKEN}" ]; then
						EXTRA_AUTH="-Dsonar.token=${EFFECTIVE_SONAR_TOKEN}"
					fi

					sonar-scanner \
						-Dsonar.host.url=${EFFECTIVE_SONAR_HOST_URL} \
						${EXTRA_AUTH} \
						-Dproject.settings=1-application-source/sonar-project.properties \
						-Dsonar.projectVersion=${BUILD_NUMBER} \
						-Dsonar.qualitygate.wait=true \
						-Dsonar.qualitygate.timeout=300
				'''
			}
		}

		stage('Quality Gate') {
			steps {
				echo 'Quality gate was enforced during scanner execution (sonar.qualitygate.wait=true).'
			}
		}

		stage('Container Security Scan (Trivy)') {
			steps {
				sh '''
					set -e

					if ! command -v trivy >/dev/null 2>&1; then
						echo "trivy not found on Jenkins host. Install: curl -sSfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin"
						exit 1
					fi

					echo "========== Scanning Dockerfiles for base image vulnerabilities =========="
					trivy config 1-application-source/vote/Dockerfile || true
					trivy config 1-application-source/worker/Dockerfile || true
					trivy config 1-application-source/result/Dockerfile || true

					echo "========== Scanning source code and dependencies for CVEs =========="
					trivy fs --severity HIGH,CRITICAL 1-application-source/vote/requirements.txt || true
					trivy fs --severity HIGH,CRITICAL 1-application-source/result/package.json || true

					echo "========== Trivy scan complete =========="
				'''
			}
		}

		stage('Deploy to ArgoCD') {
			steps {
				sh '''
					set -e

					GIT_COMMIT_SHORT=$(git rev-parse --short HEAD)
					BUILD_TAG="${GIT_COMMIT_SHORT}-${BUILD_NUMBER}"

					echo "========== ArgoCD GitOps Deployment =========="
					echo "Git Commit: ${GIT_COMMIT_SHORT}"
					echo "Build Tag: ${BUILD_TAG}"
					echo ""
					echo "Next Steps:"
					echo "1. Build container images: docker build -t vote:${BUILD_TAG} 1-application-source/vote/"
					echo "2. Update 3-gitops-manifests/voting-app-gitops-manifests with new image tags"
					echo "3. Commit & push: git commit -am 'Update image tags to ${BUILD_TAG}'"
					echo "4. ArgoCD will auto-detect and deploy"
					echo ""
					echo "ArgoCD Application: voting-app"
					echo "ArgoCD Namespace: argocd"
					echo "Target Namespace: voting-app"
					echo ""
					echo "To sync manually: argocd app sync voting-app --insecure"
					echo "Dashboard: http://<argocd-server>/applications/voting-app"
				'''
			}
		}
	}

	post {
		success {
			echo 'Pipeline completed: webhook/SCM trigger, checkout, Sonar scan, quality gate, Trivy security scan, and ArgoCD deployment steps all passed.'
		}
		failure {
			echo 'Pipeline failed. Check Sonar host/token values, scanner output, or Trivy installation.'
		}
	}
}
